# 临时文件
.DS_Store
*.log
*.tmp

# 数据文件
backend/data/
*.db
*.db-shm
*.db-wal

# 上传测试文件
uploads/
!uploads/.gitkeep

# 旧文档
/docs/.Rhistory

# ========== 大文件策略 ==========
# 默认：视频和大 PDF 不入 git（应用 OSS / CDN / 公众号文章链接）
# 例外：assets/pdfs 下的 PDF（小文件 / 教学资源）允许入 git
#       assets/videos 下的视频文件允许入 git（小文件）
*.mp4
*.mov
*.avi
*.webm
*.pdf

# 放行白名单（覆盖上面的排除规则）
!assets/**/*.pdf
!assets/**/*.mp4
!assets/**/*.webm
!assets/**/*.mov

# R / 系统临时文件
.Rhistory
*.tmp
test/
